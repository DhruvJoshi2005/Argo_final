# OpenAI
OPENAI_API_KEY=sk-proj-...

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=argo_final
DB_USER=postgres
DB_PASSWORD=your_password_here

# CORS — comma-separated list of allowed frontend origins
# Use * to allow all (dev only), or set your deployed frontend URL
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.com

# Cost / abuse protection (see rate_limit.py). All optional — sensible
# defaults apply if unset.
#   GLOBAL_RATE_PER_MIN — max requests/min across ALL clients (burst throttle)
#   IP_RATE_PER_MIN     — max requests/min per single client IP
#   LLM_DAILY_MAX       — hard cap on real (paid) OpenAI calls per day.
#                         Cache hits are free and do NOT count. Lower this to
#                         stretch a small credit balance further.
GLOBAL_RATE_PER_MIN=40
IP_RATE_PER_MIN=20
LLM_DAILY_MAX=300
